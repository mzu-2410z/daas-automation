# =============================================================================
#  .env.example
#  Copy this file to .env and fill in your real values.
#  NEVER commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Real Estate Data API  (e.g. ATTOM, Estated, PropStream, or your aggregator)
# -----------------------------------------------------------------------------
# Base URL – no trailing slash.
REALESTATE_API_BASE_URL=https://api.gateway.realestatedata.com/v1

# Your API key from the data provider portal.
REALESTATE_API_KEY=your_realestate_api_key_here

# -----------------------------------------------------------------------------
# Skip Trace / Enrichment API
# -----------------------------------------------------------------------------
# Base URL – no trailing slash.
SKIPTRACE_API_BASE_URL=https://api.skiptracegateway.com/v2

# Your API key from the skip trace provider portal.
SKIPTRACE_API_KEY=your_skiptrace_api_key_here

# -----------------------------------------------------------------------------
# Google Sheets
# -----------------------------------------------------------------------------
# Absolute or relative path to your Service Account credentials JSON file.
GOOGLE_CREDENTIALS_PATH=/home/youruser/secrets/credentials.json

# The long ID found in the Google Sheet URL:
# https://docs.google.com/spreadsheets/d/<SHEET_ID>/edit
GOOGLE_SHEET_ID=your_google_sheet_id_here

# Name of the tab (worksheet) inside the spreadsheet.
# Defaults to "Leads" if not set.
GOOGLE_SHEET_TAB_NAME=Leads

# -----------------------------------------------------------------------------
# Pipeline Parameters
# -----------------------------------------------------------------------------
# Comma-separated list of ZIP codes to query each run.
TARGET_ZIP_CODES=90210,10001,77001

# Maximum number of pre-foreclosure properties to fetch per ZIP code.
PROPERTIES_PER_ZIP=50

# -----------------------------------------------------------------------------
# Rate-limiting & Retry
# -----------------------------------------------------------------------------
# Seconds to sleep between outbound API calls (float allowed, e.g. 1.5).
REQUEST_DELAY_SECONDS=1.5

# Total number of retry attempts for transient HTTP errors (5xx, timeouts).
MAX_RETRIES=3

# Exponential back-off multiplier between retries.
# Wait = backoff_factor * (2 ** (retry_number - 1))
# e.g. factor=2 → waits: 2s, 4s, 8s
RETRY_BACKOFF_FACTOR=2.0

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Path to the log file.  Leave blank to disable file logging.
LOG_FILE=pipeline.log
